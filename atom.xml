  <entry>
    <title>Hello World!</title>
    <link href="https://blog.crisipa.icu/2023/09/29/hello-world/"/>
    <id>https://blog.crisipa.icu/2023/09/29/hello-world/</id>
    <published>2023-09-29T05:53:33.825Z</published>
